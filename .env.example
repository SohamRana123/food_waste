# Backend
# Optional: absolute path to SQLite DB file (default: <data>/CodexRuntime/kitchen_ops.sqlite)
SQLITE_DB_FILE=
API_PORT=8000
API_HOST=0.0.0.0
LOG_LEVEL=INFO

# Frontend — browser-visible API base URL
# Local dev (direct to FastAPI):
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Same-origin proxy via next.config.js rewrites (Docker Compose / single public hostname):
# NEXT_PUBLIC_API_BASE_URL=same-origin
# Docker build only: where Next.js should proxy /api/backend/* (Compose service URL)
# BACKEND_URL_FOR_REWRITE=http://backend:8000

# Weather and Holiday APIs
OPEN_METEO_BASE_URL=https://archive-api.open-meteo.com/v1
NAGER_DATE_BASE_URL=https://date.nager.at/api/v3

# MLOps Configuration
RETRAINING_INTERVAL_HOURS=24
WASTE_COST_INR=20
SHORTAGE_COST_INR=100
SERVICE_LEVEL_TARGET=0.95

# Optional: Data Ingestion
KAGGLE_USERNAME=
KAGGLE_KEY=

# Production Deployment
ENVIRONMENT=development
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1
